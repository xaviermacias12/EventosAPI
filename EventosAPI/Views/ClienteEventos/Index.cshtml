@model IEnumerable<dynamic>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Eventos";
}

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold" style="color: #1e293b;">Próximos Eventos</h1>
        <p class="text-muted">Descubre los mejores eventos y asegura tu lugar</p>
    </div>

    <div class="row g-4">
        @foreach (var evento in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                    @if (!string.IsNullOrEmpty(evento.ImagenUrl))
                    {
                        var nombreArchivo = System.IO.Path.GetFileName(evento.ImagenUrl);
                        <img src="/api/Eventos/imagen/@nombreArchivo" class="card-img-top" alt="@evento.Nombre" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-image fs-1 text-white-50"></i>
                        </div>
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold text-dark">@evento.Nombre</h5>
                            <span class="badge bg-success fs-6">$@evento.Precio.ToString("N0")</span>
                        </div>
                        <p class="card-text text-muted small">@(evento.Descripcion?.Length > 100 ? evento.Descripcion.Substring(0, 100) + "..." : evento.Descripcion)</p>
                        <div class="mt-3">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <i class="bi bi-calendar3 text-secondary"></i>
                                <span class="small">@evento.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-geo-alt text-secondary"></i>
                                <span class="small">@evento.Lugar</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="/ClienteEventos/Detalle/@evento.Id" class="btn btn-dark w-100 rounded-3">
                            Ver detalles <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @{
        // Verificar si hay elementos en el modelo
        var hayEventos = false;
        foreach (var item in Model) { hayEventos = true; break; }
    }
    @if (!hayEventos)
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x fs-1 text-muted"></i>
            <p class="text-muted mt-3">No hay eventos disponibles en este momento</p>
        </div>
    }
</div>