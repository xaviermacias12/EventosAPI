@model EventosAPI.Models.Evento
@{
    ViewData["Title"] = Model.Nombre;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var disponibles = ViewBag.Disponibles ?? Model.Capacidad;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/ClienteEventos" class="text-decoration-none">Eventos</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Nombre</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-md-6">
            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
            {
                var nombreArchivo = Model.ImagenUrl.Split('/').Last();
                <img src="/api/Eventos/imagen/@nombreArchivo" class="img-fluid rounded-4 shadow-sm w-100" alt="@Model.Nombre" style="max-height: 400px; object-fit: cover;">
            }
            else
            {
                <div class="bg-secondary rounded-4 d-flex align-items-center justify-content-center" style="height: 400px;">
                    <i class="bi bi-image fs-1 text-white-50"></i>
                </div>
            }
        </div>

        <div class="col-md-6">
            <h1 class="display-6 fw-bold" style="color: #1e293b;">@Model.Nombre</h1>

            <div class="mt-3">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <i class="bi bi-calendar3 text-secondary fs-5"></i>
                    <span>@Model.Fecha.ToString("dddd, dd MMMM yyyy - HH:mm")</span>
                </div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <i class="bi bi-geo-alt text-secondary fs-5"></i>
                    <span>@Model.Lugar</span>
                </div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <i class="bi bi-tag text-secondary fs-5"></i>
                    <span>Categoría: @(ViewBag.CategoriaNombre ?? "Sin categoría")</span>
                </div>
            </div>

            <div class="alert @(disponibles < 10 ? "alert-warning" : "alert-info") mt-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-ticket-perforated"></i> Lugares disponibles:</span>
                    <strong class="fs-4">@disponibles / @Model.Capacidad</strong>
                </div>
                @if (disponibles < 10 && disponibles > 0)
                {
                    <small class="text-danger">¡Últimos lugares disponibles!</small>
                }
                else if (disponibles == 0)
                {
                    <small class="text-danger fw-bold">Evento agotado</small>
                }
            </div>

            <div class="card bg-light border-0 rounded-4 mt-3">
                <div class="card-body">
                    <h5 class="card-title">Descripción</h5>
                    <p class="card-text">@Model.Descripcion</p>
                </div>
            </div>

            @if (User.Identity.IsAuthenticated)
            {
                <div class="card border-0 shadow-sm rounded-4 mt-4">
                    <div class="card-body">
                        <h5 class="card-title">Reservar entradas</h5>
                        <div class="row g-3 align-items-end">
                            <div class="col-6">
                                <label class="form-label">Cantidad (máx. @Math.Min(5, disponibles))</label>
                                <input type="number" id="cantidad" class="form-control form-control-lg" value="1" min="1" max="@Math.Min(5, disponibles)">
                            </div>
                            <div class="col-6">
                                <button id="btnReservar" class="btn btn-success w-100 py-2" data-id="@Model.Id">
                                    <i class="bi bi-check-circle me-2"></i> Reservar ahora
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-secondary mt-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <a href="/AuthWeb/Login?returnUrl=@Context.Request.Path" class="alert-link">Inicia sesión</a> para comprar entradas.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnReservar')?.addEventListener('click', function() {
            const eventoId = this.dataset.id;
            const cantidad = document.getElementById('cantidad').value;

            fetch('/ClienteEventos/Reservar', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `eventoId=${eventoId}&cantidad=${cantidad}`
            })
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            })
            .catch(error => console.error('Error:', error));
        });
    </script>
}